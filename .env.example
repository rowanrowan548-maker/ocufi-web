# 前端环境变量(构建时/运行时都需要,NEXT_PUBLIC_ 前缀的会暴露到浏览器)
# 复制为 .env.local 本地开发用,生产环境在 Vercel dashboard 配

# ────── Solana RPC(必需) ──────
# 推荐 Helius 免费版: https://dashboard.helius.dev/
# 没配会回退公共 mainnet-beta,getTokenAccountsByOwner 等会被严重限速
NEXT_PUBLIC_HELIUS_RPC=

# ────── Jupiter 手续费接收地址(Day 3 上线前必须配) ──────
# 流程: https://referral.jup.ag/dashboard 连钱包 → Create Account → 拿到地址
# 这是 Jupiter referral partner 程序下的你的收款账户
NEXT_PUBLIC_JUPITER_FEE_ACCOUNT=

# ────── 后端 API 地址(Day 9+ 需要) ──────
# 本地开发:http://localhost:8000
# 生产:https://xxx.up.railway.app(Railway 部署后拿到)
NEXT_PUBLIC_API_URL=

# ────── Phantom Connect SDK(可选 · OAuth google/apple 登录) ──────
# T1.6 (2026-05-01) · V1 默认 disable(connect.phantom.app/login 报 400 · 等修)
# 设 'true' 才显 Phantom Connect 入口 · 不设 / 'false' / 任意值 → 全站隐藏 · 走标准扩展
NEXT_PUBLIC_PHANTOM_CONNECT_ENABLED=false
# Phantom Portal 注册 app 拿 ID:https://phantom.com/portal
# 不配 → "Connect with Phantom" 按钮自动隐藏(走传统 wallet-adapter)
# 配错(假 ID / 大小写错)→ SDK 内部 Auth2Stamper not initialized 报错
NEXT_PUBLIC_PHANTOM_APP_ID=
# OAuth 回调落地页 · Phantom Portal 必须把这个 URL 注册到 redirect URLs 白名单
NEXT_PUBLIC_PHANTOM_REDIRECT_URL=https://www.ocufi.io/auth/phantom-callback
# 弹窗顶部 app icon(absolute URL · 默认走站点 apple-touch-icon)
NEXT_PUBLIC_PHANTOM_APP_ICON=https://www.ocufi.io/apple-touch-icon.png
